{
  "name": "@examples/sveltekit",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "SPOTIFY_EFFECT_TRACE=1 OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:14318 vite dev",
    "build": "SPOTIFY_EFFECT_TRACE=1 OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:14318 vite build",
    "preview": "SPOTIFY_EFFECT_TRACE=1 OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:14318 vite preview",
    "typecheck": "bun run --filter 'spotify-effect' build && bun run --filter @spotify-effect/otel-node build && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@spotify-effect/otel-node": "workspace:*",
    "effect": "4.0.0-beta.36",
    "spotify-effect": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  }
}
