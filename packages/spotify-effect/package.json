{
  "name": "spotify-effect",
  "version": "0.1.0",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && bun vitest run --config vite.config.ts",
    "test:watch": "bun vitest --config vite.config.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts"
  },
  "dependencies": {
    "effect": "4.0.0-beta.36"
  },
  "devDependencies": {
    "@effect/opentelemetry": "4.0.0-beta.36",
    "@opentelemetry/sdk-trace-base": "^2.6.0"
  }
}
